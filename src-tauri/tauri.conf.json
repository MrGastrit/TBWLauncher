{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "tbwlauncher",
  "version": "0.1.0",
  "identifier": "com.govno.tbwlauncher",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "TBW Launcher",
        "center": true,
        "width": 1040,
        "height": 760,
        "minWidth": 920,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "installer-hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERCQThCQzRCOTRBQTI2OUUKUldTZUpxcVVTN3lvMjhqcmU5Q2Y5ck82OUVQcG9VWmp4RkNVZmFDQTRYaG5IWEd3NTBKY3REb1EK",
      "endpoints": [
        "https://vm863690.hosted-by.u1host.com/updates/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
