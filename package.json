{
  "name": "tbwlauncher",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "updater:apply-pubkey": "powershell -ExecutionPolicy Bypass -File scripts/apply-updater-pubkey.ps1",
    "updater:prepare-release": "powershell -ExecutionPolicy Bypass -File scripts/prepare-updater-release.ps1",
    "updater:publish-release": "powershell -ExecutionPolicy Bypass -File scripts/publish-updates.ps1",
    "updater:ship-release": "npm run updater:prepare-release && npm run updater:publish-release",
    "updater:deploy": "powershell -ExecutionPolicy Bypass -File scripts/release-updater.ps1"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tauri-apps/cli": "^2.10.0",
    "@tsconfig/svelte": "^5.0.6",
    "@types/node": "^24.10.1",
    "svelte": "^5.45.2",
    "svelte-check": "^4.3.4",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "three": "^0.183.2"
  }
}
